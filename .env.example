# ADBPD — Environment Variables
# These are auto-generated on first run if .env does not exist.
# DO NOT commit .env to git.

# HMAC secrets — 64-byte hex strings, generated at install time.
ADBPD_HMAC_SECRET=
FM_HMAC_SECRET=

# Logging
ADBPD_LOG_LEVEL=info

# Optional overrides for paths
# ADBPD_CONFIG_PATH=./config/config.json
# ADBPD_DB_PATH=./data/adbpd.db
# ADBPD_LOG_DIR=./logs
