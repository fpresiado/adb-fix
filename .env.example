# ADBPD — Environment Variables
# Copy to .env and edit as needed. .env is gitignored.

# Paths
ADBPD_ADB_PATH=C:/Android/platform-tools/adb.exe
ADBPD_EMULATOR_BIN=C:/Users/<you>/AppData/Local/Android/Sdk/emulator/emulator.exe
ADBPD_DB_PATH=./adbpd.sqlite

# Ports
ADBPD_BACKEND_PORT_BASE=5040
ADBPD_ENUM_PORT=5039
ADBPD_API_HTTP_PORT=3002
ADBPD_API_WS_PORT=3003

# Comma-separated AVDs ADBPD will launch + manage. These get pinned to NUMA
# and auto-relaunched on wedge by the watchdog.
#   Format: <avdName>@<consolePort>[,<avdName>@<consolePort>...]
# ADBPD_MANAGED_AVDS=Pixel_9_Pro@5554

# Optional telemetry bridge (off by default). When enabled via PUT /config
# {fmEnabled: true}, every event in the queue gets HMAC-signed and POSTed.
# ADBPD_FM_URL=http://localhost:3001
# ADBPD_INSTALL_ID=adbpd-local
# ADBPD_FM_TOKEN=<your-token>

# Logging
ADBPD_LOG_LEVEL=info
