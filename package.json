{
  "name": "bridge",
  "version": "0.1.0",
  "description": "Sovereign multi-agent chat broker for Claude Code, Claude Desktop, and human supervisors. Fully on-device, zero cloud dependencies.",
  "type": "module",
  "private": true,
  "author": "Francisco Ricardo Preciado Jr (Future @I LLC)",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "bun run --watch src/server/broker.ts",
    "build": "bun build src/server/broker.ts --outdir dist --target bun",
    "test": "bun test",
    "lint": "tsc --noEmit",
    "start:broker": "bun run src/server/broker.ts",
    "start:tui": "bun run src/client/tui.tsx",
    "start:dashboard": "bun run src/server/broker.ts",
    "install:service": "powershell -ExecutionPolicy Bypass -File scripts/install-service.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.20.2",
    "ink": "5.2.1",
    "ink-text-input": "6.0.0",
    "pino": "9.5.0",
    "react": "18.3.1",
    "ws": "8.18.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/ws": "8.5.13",
    "bun-types": "1.1.38",
    "ink-testing-library": "4.0.0",
    "typescript": "5.7.2"
  }
}
